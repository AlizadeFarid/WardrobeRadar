{
  "manifest_version": 3,
  "name": "Wardrobe Radar - Find Clothes by Image",
  "version": "1.0",
  "description": "Select, find, and instantly shop the exact clothes you see in any video or image from trusted stores.",
  "permissions": [
    "sidePanel",
    "scripting",
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "side_panel.html"
  },
  "action": {
    "default_title": "Open Wardrobe Radar"
  },
  "commands": {
    "trigger_capture": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "MacCtrl+Shift+S"
      },
      "description": "Capture an item for Wardrobe Radar"
    }
  }
}
